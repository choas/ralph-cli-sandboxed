{
  "name": "ralph-cli-sandboxed",
  "version": "0.7.2",
  "description": "AI-driven development automation CLI for Claude Code",
  "type": "module",
  "bin": {
    "ralph": "dist/index.js",
    "ralph-cli-sandboxed": "dist/index.js",
    "ralph-mcp": "dist/mcp-server.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "npx tsc && npm run copy-config",
    "copy-config": "mkdir -p dist/config && cp src/config/*.json dist/config/",
    "dev": "npx tsx src/index.ts",
    "typecheck": "npx tsc --noEmit",
    "lint": "oxlint src/",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.15.0",
    "discord.js": "^14.16.0",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "openai": "^6.33.0",
    "react": "^19.2.4",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "cli",
    "claude",
    "claude-code",
    "ai",
    "automation",
    "prd",
    "anthropic",
    "llm",
    "developer-tools",
    "devtools"
  ],
  "author": "Lars Gregori",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/choas/ralph-cli-sandboxed.git"
  },
  "homepage": "https://github.com/choas/ralph-cli-sandboxed#readme",
  "bugs": {
    "url": "https://github.com/choas/ralph-cli-sandboxed/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "undici": "^6.23.0"
  }
}
